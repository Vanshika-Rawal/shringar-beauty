# ============================================================
# SHRINGAR — Firebase configuration
# Copy this file to ".env.local" and fill in your project values.
# Get these from Firebase Console → Project Settings → Your apps.
# ============================================================

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abcdef123456

# Optional: site URL used for SEO / sitemap / canonical links
NEXT_PUBLIC_SITE_URL=https://shringar.example.com
